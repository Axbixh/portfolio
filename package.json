{
  "name": "observatory",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c yellow,cyan \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend",
    "start": "npm run start -w backend",
    "preview": "npm run preview -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
